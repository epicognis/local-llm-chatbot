# Backend selection: ollama | anthropic | mock
LLM_BACKEND=ollama
DEFAULT_MODEL=Gemma 4 12B

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Generation defaults
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=1024
CONTEXT_SAFETY_MARGIN=768

# Context management
CONTEXT_LEVEL=0                  # 0=passthrough, 1=sliding window, 2=rolling summary
SUMMARY_TRIGGER_TOKENS=0         # Level 2: token threshold to trigger summarize(); <=0 summarizes ASAP
SLIDING_WINDOW_TURNS=12          # Level 1/2: number of most-recent turns kept verbatim

# Session storage
SESSION_DB_URL=sqlite:///./sessions.db

# Optional cloud fallback
# ANTHROPIC_API_KEY=sk-ant-...
